# Copy to scripts/calculco/phase8_p0_model_ready_job.env (gitignored) or let
# submit_phase8_p0_model_ready.sh write it at submit time.
#
# phase8_p0_model_ready.sh sources this file when present so OAR jobs receive
# the intended controls even when login-shell exports are not propagated.

# Where to start the chain: "training" (full) or "subgraphs" (resume, reuses
# completed training/ATC3/preprocessing/graph artifacts).
PHASE8_P0_START_AT=subgraphs

PHASE8_P0_RUN_FEATURES=auto
PHASE8_P0_FEATURE_VERSION=temporal-features-v2
CANDIDATE_TOKEN_STRATEGY=rxnorm_or_atc

# Subgraph edge-join memory controls. The edge builder keeps the large
# relation-specific joins on narrow integer keys, so the default 8 shards should
# fit node-local scratch. Raise SUBGRAPH_JOIN_SHARDS to 16 only if an encoded
# edge/candidate part still reports "failed to offload data block".
SUBGRAPH_BATCHES=8
SUBGRAPH_JOIN_SHARDS=8
SUBGRAPH_EDGE_THREADS=1
DUCKDB_MEMORY_LIMIT=10GB
# Optional DuckDB spill cap. "failed to offload data block ... (X GiB/X GiB
# used)" means DuckDB hit this ceiling (defaults to ~90% of free space on the
# temp drive, e.g. a small /tmp). Leave empty to auto-detect, or set a larger
# value (e.g. 150GB) when DUCKDB_TEMP_DIR points at a bigger volume.
DUCKDB_MAX_TEMP_DIR_SIZE=
