# Copy to scripts/calculco/milestone7_job.env (gitignored) or let
# submit_evaluate_baselines.sh write it at submit time.
#
# evaluate_baselines.sh sources this file when present so OAR jobs receive the
# intended Milestone 7 controls even when the login-shell export is not propagated.

MILESTONE7_MODE=development
MILESTONE7_TOP_K=1,3,5,10
MILESTONE7_FROZEN_SELECTION=0
MILESTONE7_BASELINES=random,global_popularity,condition_popularity,linear,xgboost
# Optional sepsis-only filter after B3 mappings and refreshed Milestone 6 artifacts:
# MILESTONE7_CONDITION_TOKENS=condition:sepsis
