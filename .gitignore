# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
.uv-cache/

# Secrets and environment-specific configuration
# Copy from .env.example into a machine-specific file; never commit overrides.
.env
.env.local
.env.calculco
.env.server
.env.*
!.env.example

# Optional per-machine shell exports (alternative to .env files).
environment.local.sh
environment.calculco.sh

# Machine-specific documentation and OAR overrides (copy from *.example.*).
Documentation/*.local.md
scripts/calculco/common.local.sh
scripts/calculco/oar.local.sh
scripts/calculco/milestone7_job.env
scripts/calculco/phase8_p0_milestone7_job.env
scripts/calculco/phase8_p0_milestone8b_job.env
scripts/calculco/milestone8b_job.env
scripts/calculco/phase8_p0_model_ready_job.env
scripts/calculco/phase8_p0_gate_recovery_job.env

# Editor/IDE machine settings (shared .cursor/rules/ stay tracked).
.vscode/
.idea/
*.code-workspace
.cursor/*
!.cursor/rules/
!.cursor/rules/**
*.key
*.pem
credentials.json
secrets.json

# Licensed datasets and generated research artifacts
Dataset/
derived/
outputs/
DepreciatedCode/
Models/
models/
reports/
artifacts/
*.pkl
*.joblib
*.parquet
*.feather

# OAR job logs (may contain paths; not for version control)
scripts/calculco/logs/*.out
scripts/calculco/logs/*.err
!scripts/calculco/logs/.gitkeep

# Ephemeral Calculco scratch markers (if copied into the repo by mistake)
workdir/
scratch/

# Notebook and editor state
.ipynb_checkpoints/
.DS_Store
Thumbs.db

Environment.md
