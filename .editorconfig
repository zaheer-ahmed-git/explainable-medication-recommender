root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,toml,yaml,yml,json,md,txt}]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.json]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2

[*.ipynb]
indent_size = 1
