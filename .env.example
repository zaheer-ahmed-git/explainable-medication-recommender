# Optional runtime path overrides (local workstation vs Calculco HPC).
# Python does not load this file automatically.
#
# Per-machine workflow (gitignored):
#   cp .env.example .env.local      # local workstation
#   cp .env.example .env.calculco   # ULCO Calculco server
# Then uncomment paths in the copy and: set -a && source .env.local && set +a
#
# Optional explicit layout for agents:
# RESEARCHMODULE_ENV=local            # local_monolithic
# RESEARCHMODULE_ENV=calculco_split   # Calculco / protected NFS
# RESEARCHMODULE_ENV=split_custom

# PROJECT_HOME=/path/to/ResearchModule
# DATASET_ROOT=/path/to/Dataset
# DATA_PROTECTED=/path/to/parent/of/Dataset
# REPORTS_ROOT=${PROJECT_HOME}/reports
# WORK_SCRATCH=/path/to/ephemeral/scratch
